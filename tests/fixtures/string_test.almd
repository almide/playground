effect fn main(_args: List[String]) -> Result[Unit, String] = {
  assert_eq(string.trim("  hello  "), "hello")
  assert_eq(string.len("abc"), 3)
  assert_eq(string.split("a,b,c", ","), ["a", "b", "c"])
  assert_eq(string.join(["a", "b", "c"], "-"), "a-b-c")
  assert_eq(string.replace("foo bar foo", "foo", "x"), "x bar x")
  assert_eq(string.to_upper("hello"), "HELLO")
  assert_eq(string.to_lower("HELLO"), "hello")
  assert(string.contains("hello world", "world"))
  assert(string.starts_with?("hello", "hel"))
  assert(string.ends_with?("hello", "llo"))
  assert_eq(string.chars("abc"), ["a", "b", "c"])
  assert_eq(string.index_of("hello", "ll"), some(2))
  assert_eq(string.repeat("ab", 3), "ababab")
  assert_eq(string.char_at("abc", 1), some("b"))
  assert(string.is_digit?("123"))
  assert(string.is_alpha?("abc"))
  assert(string.is_alphanumeric?("abc123"))
  assert_eq(string.slice("hello", 1, 3), "el")
  assert_eq(string.pad_left("5", 3, "0"), "005")
  assert_eq(string.to_int("42"), 42)
  println("string: ok")
}
